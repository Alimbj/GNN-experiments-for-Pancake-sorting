@dataclass(frozen=True)
class ModelConfig:
    n: int = 45
    d_model: int = 256
    depth: int = 2
    dropout: float = 0.05
    max_neighbors: int = 44
    neighbor_mode: str = "sampled"
    use_gap_feature: bool = False
    use_policy_head: bool = True
    fourier_bands: int = 4
    random_proj_dim: int = 16
    local_kernel_size: int = 3
    use_local_mixing: bool = True
    use_pyg_attn_pool: bool = True
    use_gated_pooling: bool = True
    encoder_preset: str = "full"

ABLATION_PRESETS = [
    "base", "+base", "+fourier", "+proj", "+local", "+pool", "+blocks", "full",
]

def get_config_for_preset(preset: str, n: int = 45, d_model: int = 256) -> ModelConfig:
    if preset not in ABLATION_PRESETS:
        raise ValueError(f"Unknown preset: {preset}. Available: {ABLATION_PRESETS}")
    return ModelConfig(
        n=n, d_model=d_model, depth=2, dropout=0.05,
        max_neighbors=44, neighbor_mode="sampled",
        use_gap_feature=False, use_policy_head=True,
        fourier_bands=4, random_proj_dim=16, local_kernel_size=3,
        use_local_mixing=True, use_pyg_attn_pool=True, use_gated_pooling=True,
        encoder_preset=preset,
    )

